{
  "name": "sgb-engineering-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "dev:reset": "powershell -ExecutionPolicy Bypass -Command \"if (Test-Path '.next-dev') { Remove-Item '.next-dev' -Recurse -Force }; if (Test-Path '.next') { Remove-Item '.next' -Recurse -Force }; npm run dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "import-company-profile": "powershell -ExecutionPolicy Bypass -File ./scripts/import-company-profile.ps1"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.5.0",
    "lucide-react": "^0.511.0",
    "next": "^15.5.12",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2"
  }
}
